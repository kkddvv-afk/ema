<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ЭЛМА - Тест для отдела продаж</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            background-color: #ffffff;
            color: #1a1a1a;
            line-height: 1.5;
        }

        .slide {
            width: 960px;
            height: 540px;
            margin: 0 auto 20px;
            display: flex;
            flex-direction: column;
            padding: 4rem;
            background-color: #ffffff;
            border: 1px solid #e0e0e0;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
        }

        .slide.title-slide {
            background: linear-gradient(135deg, #0284c7 0%, #0ea5e9 100%);
            color: #ffffff;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .slide.summary-slide {
            background-color: #f0f9ff;
        }

        .slide.review-slide {
            background-color: #fef3c7;
        }

        h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
            font-weight: 600;
            color: #ffffff;
        }

        .title-slide h1 {
            color: #ffffff;
        }

        h2 {
            font-size: 2rem;
            margin-bottom: 1.5rem;
            color: #0284c7;
        }

        h3 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            color: #075985;
        }

        p {
            font-size: 1.25rem;
            margin-bottom: 1rem;
            color: #ffffff;
        }

        .title-slide p {
            color: #ffffff;
            font-size: 1.25rem;
            opacity: 0.95;
        }

        .question-text {
            font-size: 1.5rem;
            font-weight: 500;
            margin-bottom: 1.5rem;
            color: #1a1a1a;
        }

        .options-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-top: 1.5rem;
        }

        .option-button {
            padding: 1rem;
            font-size: 1rem;
            border: 2px solid #0284c7;
            background-color: #ffffff;
            color: #0284c7;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 500;
            text-align: center;
            min-height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .option-button:hover {
            background-color: #e0f2fe;
            transform: translateY(-2px);
        }

        .option-button.correct {
            background-color: #10b981;
            color: #ffffff;
            border-color: #10b981;
        }

        .option-button.incorrect {
            background-color: #ef4444;
            color: #ffffff;
            border-color: #ef4444;
        }

        .option-button:disabled {
            cursor: not-allowed;
            opacity: 0.8;
        }

        .feedback {
            margin-top: 1.5rem;
            padding: 1rem;
            border-radius: 8px;
            font-weight: 500;
            font-size: 1.1rem;
            text-align: center;
            display: none;
        }

        .feedback.show {
            display: block;
        }

        .feedback.correct-feedback {
            background-color: #d1fae5;
            color: #065f46;
            border-left: 4px solid #10b981;
        }

        .feedback.incorrect-feedback {
            background-color: #fee2e2;
            color: #7f1d1d;
            border-left: 4px solid #ef4444;
        }

        .stats-container {
            display: flex;
            justify-content: space-around;
            margin: 2rem 0;
            gap: 2rem;
        }

        .stat-box {
            flex: 1;
            padding: 1.5rem;
            border-radius: 8px;
            text-align: center;
            font-weight: 600;
        }

        .stat-correct {
            background-color: #d1fae5;
            color: #065f46;
        }

        .stat-incorrect {
            background-color: #fee2e2;
            color: #7f1d1d;
        }

        .stat-score {
            background-color: #dbeafe;
            color: #075985;
        }

        .stat-number {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
        }

        .stat-label {
            font-size: 1rem;
        }

        .review-item {
            background-color: #ffffff;
            padding: 1.5rem;
            margin-bottom: 1rem;
            border-radius: 8px;
            border-left: 4px solid #ef4444;
        }

        .review-question {
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #1a1a1a;
        }

        .review-your-answer {
            color: #ef4444;
            margin-bottom: 0.5rem;
        }

        .review-correct-answer {
            color: #10b981;
            font-weight: 500;
        }

        .slide-number {
            position: absolute;
            bottom: 1rem;
            right: 1rem;
            font-size: 0.9rem;
            color: #999;
        }

        .title-slide .slide-number {
            color: rgba(255, 255, 255, 0.5);
        }

        .end-message {
            font-size: 2rem;
            font-weight: 600;
            color: #10b981;
            text-align: center;
            margin-top: 2rem;
        }
    </style>
</head>
