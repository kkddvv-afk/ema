<!-- Slide 32-60: Review slides for incorrect answers -->
<div id="reviewContainer"></div>

<script>
    let answers = {
        correct: 0,
        incorrect: 0,
        errors: []
    };

    let currentQuestion = 0;
    const totalQuestions = 29;

    function checkAnswer(button, isCorrect) {
        const buttons = button.parentElement.querySelectorAll('.option-button');
        const feedback = button.parentElement.parentElement.querySelector('.feedback');
        
        // Disable all buttons
        buttons.forEach(btn => btn.disabled = true);

        if (isCorrect) {
            button.classList.add('correct');
            feedback.classList.add('show', 'correct-feedback');
            feedback.innerHTML = '✓ Правильно!';
            answers.correct++;
        } else {
            button.classList.add('incorrect');
            // Find and highlight the correct answer
            buttons.forEach(btn => {
                if (btn.getAttribute('onclick').includes('true')) {
                    btn.classList.add('correct');
                }
            });
            feedback.classList.add('show', 'incorrect-feedback');
            feedback.innerHTML = '✗ Неправильно. Правильный ответ выделен зелёным.';
            answers.incorrect++;
            
            // Store error info
            const question = button.parentElement.parentElement.querySelector('.question-text').innerHTML;
            const userAnswer = button.innerHTML;
            const correctAnswer = Array.from(buttons).find(btn => btn.getAttribute('onclick').includes('true')).innerHTML;
            answers.errors.push({ question, userAnswer, correctAnswer });
        }

        currentQuestion++;
        updateSummary();
    }

    function updateSummary() {
        const totalAnswered = answers.correct + answers.incorrect;
        if (totalAnswered === totalQuestions) {
            const percentage = Math.round((answers.correct / totalQuestions) * 100);
            document.getElementById('correctCount').innerHTML = answers.correct;
            document.getElementById('incorrectCount').innerHTML = answers.incorrect;
            document.getElementById('scorePercent').innerHTML = percentage + '%';
            
            let message = '';
            if (percentage === 100) {
                message = 'Отлично! Вы идеально знаете продукцию ЭЛМА!';
            } else if (percentage >= 80) {
                message = 'Хорошо! У вас крепкие знания продукции.';
            } else if (percentage >= 60) {
                message = 'Удовлетворительно. Рекомендуется повторить материал.';
            } else {
                message = 'Нужно более тщательно изучить продукцию ЭЛМА.';
            }
            document.getElementById('endMessage').innerHTML = message;
            
            // Generate review slides
            generateReviewSlides();
        }
    }

    function generateReviewSlides() {
        const container = document.getElementById('reviewContainer');
        
        if (answers.errors.length === 0) {
            // Perfect score - no errors to review
            const slide = document.createElement('section');
            slide.className = 'slide review-slide';
            slide.innerHTML = `
                <h2>Обзор ошибок</h2>
                <div style="text-align: center; padding: 3rem; color: #059669; font-size: 1.5rem; font-weight: 600;">
                    Ошибок не обнаружено!<br><br>
                    Вы прошли тест без ошибок. Отличная подготовка отдела!
                </div>
                <div class="slide-number">32 / 32</div>
            `;
            container.appendChild(slide);
        } else {
            answers.errors.forEach((error, index) => {
                const slide = document.createElement('section');
                slide.className = 'slide review-slide';
                slide.innerHTML = `
                    <h2>Ошибка ${index + 1} из ${answers.errors.length}</h2>
                    <div class="review-item">
                        <div class="review-question"><strong>Вопрос:</strong> ${error.question}</div>
                        <div class="review-your-answer"><strong>Ваш ответ:</strong> ${error.userAnswer}</div>
                        <div class="review-correct-answer"><strong>Правильный ответ:</strong> ${error.correctAnswer}</div>
                    </div>
                    <div class="slide-number">${32 + index} / ${31 + answers.errors.length}</div>
                `;
                container.appendChild(slide);
            });
        }
    }
</script>

